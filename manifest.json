{
  "id": "/ps2-strike",
  "name": "PS2-Strike",
  "short_name": "PS2-Strike",
  "description": "PS2-Strike (Counter-Strike)",
  "lang": "en-US",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "orientation": "natural",
  "theme_color": "#FFFFFF",
  "background_color": "#5A5A5A",
  "categories": [
    "DOCS", "EDITED", "FILES", "ORIGINAL"
  ],
  "permissions": [
    "notifications"
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "protocol_handlers": [
    {
      "protocol": "asset",
      "url": "/?asset=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "application/x-halflife-pak": [
          ".pak"
        ],
        "application/x-halflife-wad": [
          ".wad"
        ],
        "application/x-valve-vpk": [
          ".vpk"
        ]
      }
    }
  ],
  "shortcuts": [
    {
      "name": "Open Counter-Strike",
      "short_name": "CS",
      "url": "/index.html?game=cstrike"
    },
    {
      "name": "Open Half-Life",
      "short_name": "HL",
      "url": "/index.html?game=halflife"
    }
  ],
  "icons": [
    {
      "src": "ORIGINAL/PC/cstrike/cstrike.ico",
      "sizes": "any",
      "type": "image/x-icon"
    },
    {
      "src": "icons/square-icon.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/icon.png",
      "sizes": "256x256",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "icons/mipmap-mdpi/ic_launcher.png",
      "sizes": "48x48",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/mipmap-hdpi/ic_launcher.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/mipmap-xhdpi/ic_launcher.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/mipmap-xxhdpi/ic_launcher.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "icons/mipmap-xxxhdpi/ic_launcher.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "EDITED/PC/cstrike/resource/shell/splash.png",
      "sizes": "640x480",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Wallpaper"
    },
    {
      "src": "graph/screenshots/checkbox-off.png",
      "sizes": "615x974",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "O Pontual - Desligado"
    },
    {
      "src": "graph/screenshots/checkbox-on.png",
      "sizes": "615x974",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "O Pontual - Ligado"
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
    "permissions": [
        "notifications"
  ]
}
